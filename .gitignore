# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Local environments and caches
.venv/
venv/
.uv-cache/
.cache/

# OS/editor noise
.DS_Store
Thumbs.db

# Local secrets
.env
.env.*
!.env.example

# Generated local reports/artifacts
reports/
*.audit.md
*.audit.json
*.audit-source.md
*.source-map.json

# Local planning/build notes
implementation-build-log.md
merged-legal-research-agent*.md

# Local agent workbench for scratch plans, session notes, and logs.
.agent-work/

# Local user configuration (created by /onboard)
user-config.json
!templates/user-config.example.json

# Generated knowledge directories (created by /onboard --build-knowledge).
# Tracked dirs are listed in user-config.json's
# generated_knowledge_directories. By default they are gitignored;
# remove specific paths from the ignore list only when intentionally
# committing reviewed knowledge to share.
knowledge/*-*/
!knowledge/game-regulation/
!knowledge/general/
!knowledge/legal-writing/
!knowledge/onboarding/
!knowledge/output-modes/

# Library ingest workspace (gitignored — local source materials).
# Excludes contents (inbox/, grade-{a,b,c}/, etc.) but keeps the
# placeholder _index.md so the path always exists on a fresh clone.
library/*
!library/_index.md
